<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/valor1"
            android:id="@+id/valor1"
            android:layout_centerHorizontal="true"
            android:layout_alignStart="@+id/input1"
            android:layout_above="@+id/input1"
            />
        <EditText
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:id="@+id/input1"
            android:layout_above="@+id/valor2"
            android:inputType="number"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="50dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/valor2"
            android:id="@+id/valor2"
            android:layout_centerHorizontal="true"
            android:layout_above="@id/input2"
            android:layout_alignStart="@id/input2"

            />
        <EditText
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:id="@+id/input2"
            android:layout_above="@id/button"
            android:inputType="number"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="50dp"/>

        <Button
            android:layout_width="55dp"
            android:layout_height="wrap_content"

            android:text="@string/add_button"

            android:tag="soma"

            android:layout_toStartOf="@id/button"
            android:layout_centerVertical="true"
            />

        <Button
            android:layout_width="55dp"
            android:layout_height="wrap_content"

            android:tag="subtracao"

            android:text="@string/minus_button"
            android:id="@+id/button"

            android:layout_toStartOf="@id/input2"
            android:layout_centerVertical="true"
            />

        <Button
            android:layout_width="55dp"
            android:layout_height="wrap_content"

            android:tag="multiplicacao"

            android:text="@string/multiply_button"
            android:id="@+id/button2"
            android:layout_below="@id/input2"
            android:layout_toEndOf="@id/input2" />
        <Button
            android:layout_width="55dp"
            android:layout_height="wrap_content"

            android:tag="divisao"
            android:text="@string/divide_button"
            android:layout_below="@id/input2"
            android:layout_toEndOf="@id/button2" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/result_text"

            android:layout_below="@id/button"

            android:id="@+id/result"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:id="@+id/output"

            android:layout_below="@id/button2"
            android:layout_alignEnd="@id/result"
            android:layout_marginTop="50dp"/>


</RelativeLayout>